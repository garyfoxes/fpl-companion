{
  "servers": {
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": ["@playwright/mcp", "-y", "--browser", "chromium"]
    },
    "chrome-devtools": {
      "type": "stdio",
      "command": "${workspaceFolder}/.vscode/start-mcp-chrome.sh",
      "args": ["--autoConnect"],
      "env": {
        "CDP_URL": "http://localhost:9222"
      }
    }
  }
}
